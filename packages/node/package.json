{
  "name": "@manifest-network/manifest-mcp-node",
  "version": "0.1.0",
  "description": "Node.js MCP servers for Manifest Network with stdio transport and keyfile wallet",
  "type": "module",
  "bin": {
    "manifest-mcp-chain": "dist/chain.js",
    "manifest-mcp-lease": "dist/lease.js",
    "manifest-mcp-fred": "dist/fred.js"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "cosmos",
    "blockchain",
    "manifest",
    "stdio"
  ],
  "author": "Felix C. Morency",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@cosmjs/amino": "0.32.4",
    "@cosmjs/encoding": "0.32.4",
    "@cosmjs/proto-signing": "0.32.4",
    "@manifest-network/manifest-mcp-core": "*",
    "@manifest-network/manifest-mcp-chain": "*",
    "@manifest-network/manifest-mcp-lease": "*",
    "@manifest-network/manifest-mcp-fred": "*",
    "@modelcontextprotocol/sdk": "1.25.3",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "20.19.30",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
