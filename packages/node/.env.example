# Required
COSMOS_CHAIN_ID=manifest-ledger-beta

# One of COSMOS_RPC_URL or COSMOS_REST_URL is required.
# Set COSMOS_RPC_URL (+ COSMOS_GAS_PRICE) for full access (queries + transactions).
# Set COSMOS_REST_URL alone for query-only mode (no signing).
# When both are set, COSMOS_REST_URL is preferred for queries.
COSMOS_RPC_URL=https://nodes.chandrastation.com/rpc/manifest/
COSMOS_GAS_PRICE=0.01umfx
# COSMOS_REST_URL=https://nodes.chandrastation.com/api/manifest/

# Optional — wallet via env mnemonic (fallback if no keyfile exists)
# COSMOS_MNEMONIC=your twelve word mnemonic phrase goes here ...

# Optional — encrypted keyfile wallet (preferred over mnemonic)
# MANIFEST_KEY_FILE=~/.manifest/key.json
# MANIFEST_KEY_PASSWORD=your-keyfile-password

# Optional — bech32 prefix (default: manifest)
# COSMOS_ADDRESS_PREFIX=manifest

# Optional — gas simulation multiplier (default: 1.5, must be >= 1)
# COSMOS_GAS_MULTIPLIER=1.5

# Optional — absolute per-transaction gas-limit ceiling (default: 50000000; -1 disables).
# A broadcast whose ceil(simulate × multiplier) exceeds it aborts with GAS_LIMIT_EXCEEDED.
# COSMOS_MAX_GAS=50000000

# Optional — enables the `request_faucet` tool on the chain server
# MANIFEST_FAUCET_URL=https://faucet.example.com

# Required only for the cosmwasm server — bech32 address of the MFX→PWR converter
# MANIFEST_CONVERTER_ADDRESS=manifest1...

# Optional — fred server: SSRF guard for outbound provider/Fred HTTP.
# Default: 1 (on). Set to 0 to disable (not recommended). Accepts
# 1/true/yes/on and 0/false/no/off (case-insensitive).
# MANIFEST_FRED_FETCH_GUARDED=1

# Optional — agent server (manifest-mcp-agent) only:
# Directory for deploy manifest persistence. NOTE: read verbatim — `~` is NOT
# expanded for these agent paths (unlike MANIFEST_KEY_FILE); use an absolute path.
# MANIFEST_AGENT_DATA_DIR=/home/youruser/.manifest/agent
# Chain data file for denom-map humanization (loaded once at startup; `~` not expanded).
# MANIFEST_CHAIN_DATA_FILE=/home/youruser/.manifest/chain-data.json
# SSRF guard for agent-core outbound fetch (default: 1 / on; same parser as fred's).
# MANIFEST_AGENT_FETCH_GUARDED=1
# Per-elicitInput timeout in milliseconds (default: 600000 = 10 min).
# MANIFEST_AGENT_ELICIT_TIMEOUT_MS=600000

# Optional — log verbosity for stderr output (default: warn)
# Accepted values: debug, info, warn, error, silent
# LOG_LEVEL=warn
