# Required
COSMOS_CHAIN_ID=manifest-ledger-beta
COSMOS_RPC_URL=https://nodes.chandrastation.com/rpc/manifest/
COSMOS_GAS_PRICE=0.01umfx

# Optional — wallet via env mnemonic (fallback if no keyfile exists)
# COSMOS_MNEMONIC=your twelve word mnemonic phrase goes here ...

# Optional — encrypted keyfile wallet (preferred over mnemonic)
# MANIFEST_KEY_FILE=~/.manifest/key.json
# MANIFEST_KEY_PASSWORD=your-keyfile-password

# Optional
# COSMOS_ADDRESS_PREFIX=manifest
