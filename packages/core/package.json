{
  "name": "@manifest-network/manifest-mcp-core",
  "version": "0.11.0",
  "description": "Shared library for Cosmos SDK blockchain logic, tool functions, and server utilities (Manifest Network)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./__test-utils__/mocks.js": {
      "import": "./dist/__test-utils__/mocks.js",
      "types": "./dist/__test-utils__/mocks.d.ts"
    },
    "./__test-utils__/callTool.js": {
      "import": "./dist/__test-utils__/callTool.js",
      "types": "./dist/__test-utils__/callTool.d.ts"
    },
    "./__test-utils__/callToolWithElicitation.js": {
      "import": "./dist/__test-utils__/callToolWithElicitation.js",
      "types": "./dist/__test-utils__/callToolWithElicitation.d.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "cosmos",
    "cosmjs",
    "blockchain",
    "manifest"
  ],
  "author": "Felix C. Morency",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manifest-network/manifest-mcp-mono.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/manifest-network/manifest-mcp-mono#readme",
  "bugs": "https://github.com/manifest-network/manifest-mcp-mono/issues",
  "engines": {
    "node": ">=22.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@cosmjs/amino": "0.32.4",
    "@cosmjs/encoding": "0.32.4",
    "@cosmjs/proto-signing": "0.32.4",
    "@cosmjs/stargate": "npm:@manifest-network/stargate@0.32.4-ll.3",
    "@manifest-network/manifestjs": "2.4.1",
    "@modelcontextprotocol/sdk": "1.27.1",
    "ipaddr.js": "2.4.0",
    "limiter": "3.0.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "undici": "8.2.0"
  },
  "devDependencies": {
    "@types/node": "22.15.29",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "peerDependencies": {
    "vitest": "^4.1.0"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  }
}
