{
  "name": "@manifest-network/manifest-mcp-chain",
  "version": "0.17.0",
  "description": "MCP server for Cosmos SDK chain operations (queries, transactions, module discovery)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "cosmos",
    "blockchain",
    "manifest"
  ],
  "author": "Felix C. Morency",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manifest-network/manifest-mcp-mono.git",
    "directory": "packages/chain"
  },
  "homepage": "https://github.com/manifest-network/manifest-mcp-mono#readme",
  "bugs": "https://github.com/manifest-network/manifest-mcp-mono/issues",
  "engines": {
    "node": ">=22.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@manifest-network/manifest-mcp-core": "^0.17.0"
  },
  "devDependencies": {
    "@manifest-network/manifest-mcp-core": "0.17.0",
    "@types/node": "22.19.19",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  }
}
