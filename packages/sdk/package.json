{
  "name": "@manifest-network/manifest-sdk",
  "version": "0.17.0",
  "description": "Aggregating SDK for building apps on Manifest + Fred (composes @manifest-network/* over manifestjs).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "keywords": [
    "manifest",
    "cosmos",
    "cosmjs",
    "blockchain",
    "sdk",
    "fred",
    "deploy"
  ],
  "author": "Felix C. Morency",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manifest-network/manifest-mcp-mono.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/manifest-network/manifest-mcp-mono#readme",
  "bugs": "https://github.com/manifest-network/manifest-mcp-mono/issues",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./reads": {
      "types": "./dist/reads.d.ts",
      "import": "./dist/reads.js"
    },
    "./catalog": {
      "types": "./dist/catalog.d.ts",
      "import": "./dist/catalog.js"
    },
    "./deploy": {
      "types": "./dist/deploy.d.ts",
      "import": "./dist/deploy.js"
    },
    "./orchestration": {
      "types": "./dist/orchestration.d.ts",
      "import": "./dist/orchestration.js"
    },
    "./chain": {
      "types": "./dist/chain.d.ts",
      "import": "./dist/chain.js"
    },
    "./faucet": {
      "types": "./dist/faucet.d.ts",
      "import": "./dist/faucet.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "node": "./dist/node.js",
      "default": null
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "tsc --noEmit",
    "test": "vitest run --typecheck",
    "test:types": "vitest run --typecheck",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@manifest-network/manifest-mcp-core": "0.17.0",
    "@manifest-network/manifest-mcp-fred": "0.17.0",
    "@manifest-network/manifest-agent-core": "0.17.0"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "vitest": "4.1.8",
    "@types/node": "22.19.19",
    "publint": "0.3.21",
    "@arethetypeswrong/core": "0.18.3",
    "rolldown": "1.0.3"
  }
}
