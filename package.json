{
  "name": "manifest-mcp-mono",
  "version": "0.19.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces --if-present",
    "depcruise": "depcruise packages examples --config .dependency-cruiser.cjs",
    "check": "biome check packages/ examples/",
    "check:fix": "biome check --write packages/ examples/",
    "format": "biome format --write packages/ examples/",
    "test": "npm run test --workspaces --if-present",
    "pretest:e2e": "npm run build -w @manifest-network/sdk-acceptance",
    "test:e2e": "vitest run --config e2e/vitest.config.ts",
    "size": "size-limit",
    "release:version": "node scripts/version.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@size-limit/preset-small-lib": "12.1.0",
    "dependency-cruiser": "17.4.3",
    "size-limit": "12.1.0",
    "tsdown": "0.22.13",
    "vitest": "4.1.10"
  },
  "overrides": {
    "ipaddr.js": "2.4.0",
    "@cosmjs/stargate": "npm:@manifest-network/stargate@0.32.4-ll.3",
    "axios": "1.16.1",
    "protobufjs": "7.6.2"
  }
}
