{
  "name": "manifest-mcp-mono",
  "version": "0.14.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces --if-present",
    "depcruise": "depcruise packages examples --config .dependency-cruiser.cjs",
    "check": "biome check packages/ examples/",
    "check:fix": "biome check --write packages/",
    "format": "biome format --write packages/",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "vitest run --config e2e/vitest.config.ts",
    "release:version": "node scripts/version.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@modelcontextprotocol/sdk": "1.29.0",
    "dependency-cruiser": "17.4.3",
    "tsdown": "0.22.1",
    "vitest": "4.1.8"
  },
  "overrides": {
    "ipaddr.js": "2.4.0",
    "@cosmjs/stargate": "npm:@manifest-network/stargate@0.32.4-ll.3",
    "axios": "1.16.1",
    "protobufjs": "7.6.2"
  }
}
